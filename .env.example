# Copy to .env for local development only. Do not commit .env.
# Values here are placeholders; replace them with your own secrets locally or in your deployment secret manager.

# Gateway runtime
GATEWAY_CONFIG_PATH=./config.yaml
PORT=3000
OZ_API_BASE_URL=https://app.warp.dev/api/v1

# Example Slack bot -> Oz environment
ASSISTANT_SLACK_BOT_TOKEN=<slack-bot-oauth-token>
ASSISTANT_SLACK_SIGNING_SECRET=your-slack-signing-secret
ASSISTANT_OZ_API_KEY=<oz-api-key>
ASSISTANT_OZ_ENVIRONMENT_ID=your-oz-environment-id

# Example generic JSON webhook -> Oz environment
JSON_TASK_OZ_API_KEY=<oz-api-key>
JSON_TASK_OZ_ENVIRONMENT_ID=your-oz-environment-id
JSON_TASK_WEBHOOK_AUTH_TOKEN=replace-with-a-long-random-token
JSON_TASK_SKILL_SPEC=owner/repository:path/to/SKILL.md

# Example generic event-forwarding webhook -> Oz environment
EVENT_FORWARDER_OZ_API_KEY=<oz-api-key>
EVENT_FORWARDER_OZ_ENVIRONMENT_ID=your-oz-environment-id
EVENT_FORWARDER_WEBHOOK_AUTH_TOKEN=replace-with-a-long-random-token
EVENT_FORWARDER_SKILL_SPEC=owner/repository:path/to/SKILL.md

# Do not put MCP server secrets here unless the gateway process itself needs them.
# MCP secrets referenced inside config.example.yaml under mcp_servers should be created as Oz-managed secrets instead.
